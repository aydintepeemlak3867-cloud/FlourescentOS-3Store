    def send_message(self):
        user_text = self.input_area.toPlainText().strip()
        if not user_text:
            return

        self.chat_area.append(f"Kullanıcı: {user_text}")
        self.input_area.clear()

        ai_response = random.choice(self.responses)
        self.chat_area.append(f"Rüveyda: {ai_response}\n\n(Output ~{self.max_output_tokens} tokens, Params={self.params})")

from PyQt6.QtWidgets import QWidget, QVBoxLayout, QTextEdit, QPushButton
import random

class SudeAI(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Sude - Kozmetik & Güzellik Uzmanı")
        self.resize(500, 400)

        layout = QVBoxLayout()
        self.setLayout(layout)

        self.chat_area = QTextEdit()
        self.chat_area.setReadOnly(True)
        layout.addWidget(self.chat_area)

        self.input_area = QTextEdit()
        self.input_area.setFixedHeight(60)
        layout.addWidget(self.input_area)

        send_btn = QPushButton("Gönder")
        send_btn.clicked.connect(self.send_message)
        layout.addWidget(send_btn)

        # Model özellikleri
        self.params = 16384
        self.max_output_tokens = 1000

