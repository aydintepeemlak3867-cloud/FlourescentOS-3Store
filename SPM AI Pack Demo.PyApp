from PyQt6.QtWidgets import QApplication, QWidget, QVBoxLayout, QComboBox, QPushButton
import sys

# Burada senin AI class’ların import edilmiş olacak
# örn: from ai_modules import SibelAI, HasanAI, SevvalAI, IlgınAI, RumeysaAI, RuveydaAI, SudeAI

class AISelector(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("AI Seçici - Multi Rehber")
        self.resize(400, 200)

        layout = QVBoxLayout()
        self.setLayout(layout)

        self.combo = QComboBox()
        self.combo.addItems([
            "Sibel - Müzik & Sanat",
            "Hasan - Hayvan Bakım",
            "Şevval - Fitness",
            "Ilgın - Psikoloji",
            "Rumeysa - Tıp",
            "Ruveyda - Kodlama",
            "Sude - Kozmetik"
        ])
        layout.addWidget(self.combo)

        open_btn = QPushButton("AI Aç")
        open_btn.clicked.connect(self.open_ai)
        layout.addWidget(open_btn)

    def open_ai(self):
        choice = self.combo.currentText()
        if "Sibel" in choice:
            self.ai_window = SibelAI()
        elif "Hasan" in choice:
            self.ai_window = HasanAI()
        elif "Şevval" in choice:
            self.ai_window = SevvalAI()
        elif "Ilgın" in choice:
            self.ai_window = IlgınAI()
        elif "Rumeysa" in choice:
            self.ai_window = RumeysaAI()
        elif "Ruveyda" in choice:
            self.ai_window = RuveydaAI()
        elif "Sude" in choice:
            self.ai_window = SudeAI()
        self.ai_window.show()

if __name__ == "__main__":
    app = QApplication(sys.argv)
    selector = AISelector()
    selector.show()
    sys.exit(app.exec())
