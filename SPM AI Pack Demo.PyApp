            "yanıt: Şarkı söylerken sesini zorlamamaya dikkat et.",
            "yanıt: Heykelde malzeme dayanıklılığı önemlidir.",
            "yanıt: Müzikte doğaçlama özgünlük katar."
            "yanıt: Çizimde oran-orantı doğru olmalı.",
            "yanıt: Şarkı yazarken duygularını aktar.",
            "yanıt: Piyanoda gam çalışmak parmak hızını artırır.",
            "yanıt: Resimde ışık kullanımı önemlidir.",
            "yanıt: Keman çalarken parmak pozisyonlarını çalış.",
            "yanıt: Sanat akımlarını öğrenmek yaratıcılığı artırır.",
            "yanıt: Şarkı söylerken nefes kontrolü yap.",
            "yanıt: Yağlı boya tabloda katmanlı çalışmak derinlik verir.",
            "yanıt: Müzikte tempo tutmak grup uyumunu sağlar.",
            "yanıt: Çizimde gölgelendirme derinlik katar.",
            "yanıt: Nota bilgisi müzikte temel taştır.",
            "yanıt: Renk uyumu resimde göz alıcılığı artırır.",
            "yanıt: Şarkı söylerken ses aralığını bilmek önemlidir.",
            "yanıt: Heykelde detay işçilik sanatın değerini artırır.",
            "yanıt: Müzikte armoni kulağı geliştirmek için çalış.",
            "yanıt: Çizimde perspektif derinlik sağlar.",
            "yanıt: Şarkı yazarken ritim duygusunu koru.",
            "yanıt: Piyanoda parmak egzersizleri yap.",
            "yanıt: Resimde fırça seçimi önemlidir.",
            "yanıt: Keman çalarken yay hareketini kontrol et.",
            "yanıt: Sanat tarihi bilmek eserleri anlamanı sağlar.",
            "yanıt: Şarkı söylerken sesini doğru kullan.",
            "yanıt: Yağlı boya tabloda renk geçişleri önemlidir.",
            "yanıt: Müzikte metronom kullanmak ritmi geliştirir.",
            "yanıt: Çizimde detaylar eseri zenginleştirir."

        ]

    def send_message(self):
        user_text = self.input_area.toPlainText().strip()
        if not user_text:
            return

        self.chat_area.append(f"Kullanıcı: {user_text}")
        self.input_area.clear()

        ai_response = random.choice(self.responses)
        self.chat_area.append(f"Sibel: {ai_response}\n\n(Output ~{self.max_output_tokens} tokens, Params={self.params})")

from PyQt6.QtWidgets import QWidget, QVBoxLayout, QTextEdit, QPushButton
