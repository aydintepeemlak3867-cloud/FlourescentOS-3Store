from PyQt6.QtWidgets import QWidget, QVBoxLayout, QTextEdit, QPushButton
import random

class IlgınAI(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Ilgın - Psikolojik Rehber")
        self.resize(500, 400)

        layout = QVBoxLayout()
        self.setLayout(layout)

        self.chat_area = QTextEdit()
        self.chat_area.setReadOnly(True)
        layout.addWidget(self.chat_area)

        self.input_area = QTextEdit()
        self.input_area.setFixedHeight(60)
        layout.addWidget(self.input_area)

        send_btn = QPushButton("Gönder")
        send_btn.clicked.connect(self.send_message)
        layout.addWidget(send_btn)

        # Model özellikleri
        self.params = 16384
        self.max_output_tokens = 1000

        # 100 farklı yanıt (örnek olarak ilk 10’u gösteriyorum)
        self.responses = [
"yanıt: Seni anlıyorum, bu duygularla baş etmek kolay değil.",
"yanıt: Kendine zaman tanıman çok önemli.",
"yanıt: Bunu paylaşman cesaret gerektirir, tebrik ederim.",
"yanıt: Zor bir süreç olabilir ama yalnız değilsin.",
"yanıt: Her duygunun bir anlamı vardır, onları bastırma.",
"yanıt: Kendi iç sesini dinlemek iyileşmenin ilk adımıdır.",
"yanıt: Bazen küçük adımlar büyük değişim yaratır.",
"yanıt: Nefes egzersizleri sana yardımcı olabilir.",
"yanıt: Günlük yazılar yazmak duygularını düzenler.",
"yanıt: Güvendiğin biriyle konuşmak seni rahatlatır.",
"yanıt: Sabırlı ol, süreç zaman alabilir.",
"yanıt: Kendine şefkat göstermek çok önemlidir.",
"yanıt: Zihnin karmaşık olabilir ama sen kontrol edebilirsin.",
"yanıt: Paylaşmak yükünü hafifletir.",
"yanıt: Kendi ihtiyaçlarını fark etmek seni güçlendirir.",
"yanıt: Duygularını kabul etmek iyileşmenin başlangıcıdır.",
"yanıt: Kendini ifade etmek seni özgürleştirir.",
"yanıt: Zor zamanlarda destek almak önemlidir.",
"yanıt: Küçük başarılarını kutlamayı unutma.",
"yanıt: Kendi değerini bilmek seni korur.",
"yanıt: Hayat bazen ağır gelebilir ama sen güçlüsün.",
"yanıt: Kendi sınırlarını çizmek sağlıklıdır.",
"yanıt: Duygularını anlamak seni daha bilinçli yapar.",
"yanıt: Kendine güvenmek iyileşmenin anahtarıdır.",
"yanıt: Her gün biraz daha iyi olabilirsin."
"yanıt: İçinde bulunduğun durumu kabul etmek seni rahatlatır.",
"yanıt: Zor zamanlarda nefes almak bile güç verir.",
"yanıt: Kendini dinlemek en büyük rehberindir.",
"yanıt: Duygularını yazıya dökmek seni özgürleştirir.",
"yanıt: Küçük adımlar seni ileriye taşır.",
"yanıt: Kendine güvenmek seni güçlü kılar.",
