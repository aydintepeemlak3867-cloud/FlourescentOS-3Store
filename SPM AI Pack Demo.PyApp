from PyQt6.QtWidgets import QWidget, QVBoxLayout, QTextEdit, QPushButton
import random

class RuveydaAI(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Rüveyda - Kodlama Uzmanı")
        self.resize(500, 400)

        layout = QVBoxLayout()
        self.setLayout(layout)

        self.chat_area = QTextEdit()
        self.chat_area.setReadOnly(True)
        layout.addWidget(self.chat_area)

        self.input_area = QTextEdit()
        self.input_area.setFixedHeight(60)
        layout.addWidget(self.input_area)

        send_btn = QPushButton("Gönder")
        send_btn.clicked.connect(self.send_message)
        layout.addWidget(send_btn)

        # Model özellikleri
        self.params = 16384
        self.max_output_tokens = 1000

        # Örnek yanıtlar (100 olacak, burada ilk 10’u gösteriyorum)
        self.responses = [
            "yanıt: Bu kodu Python’da şöyle yazabilirsin: print('Merhaba Dünya').",
            "yanıt: Hata mesajını paylaş, debug edelim.",
            "yanıt: Bence burada bir fonksiyon tanımlamak mantıklı olur.",
            "yanıt: Döngü kullanarak tekrar eden işlemleri kolaylaştırabilirsin.",
            "yanıt: Kodunu modüllere ayırmak okunabilirliği artırır.",
            "yanıt: Try/Except blokları hata yönetimi için idealdir.",
            "yanıt: List comprehension Python’da çok güçlüdür.",
            "yanıt: C dilinde printf ile ekrana yazdırabilirsin.",
            "yanıt: JavaScript’te console.log kullanabilirsin.",
            "yanıt: Algoritmanı önce kağıtta tasarlamak işini kolaylaştırır.",
            "yanıt: Bu kodu Python’da şöyle yazabilirsin: print('Merhaba Dünya').",
            "yanıt: Hata mesajını paylaş, debug edelim.",
            "yanıt: Bence burada bir fonksiyon tanımlamak mantıklı olur.",
            "yanıt: Döngü kullanarak tekrar eden işlemleri kolaylaştırabilirsin.",
